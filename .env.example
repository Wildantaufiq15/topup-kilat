# Topup Kilat - Environment Variables

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Topup Kilat

# API (Backend will be separate service)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Backend Database (for NestJS API)
# DATABASE_URL="postgresql://postgres:password@localhost:5432/topupkilat?schema=public"

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Payment Gateway (Sakurupiah)
SAKURUPIAH_API_URL=https://api.sakurupiah.com
SAKURUPIAH_MERCHANT_ID=your-merchant-id
SAKURUPIAH_API_KEY=your-api-key
SAKURUPIAH_WEBHOOK_SECRET=your-webhook-secret

# Supplier API (Game top up providers)
SUPPLIER_API_URL=https://api.supplier-example.com
SUPPLIER_API_KEY=your-supplier-api-key
SUPPLIER_WEBHOOK_SECRET=your-supplier-webhook-secret

# Database (for future backend)
DATABASE_URL=postgresql://user:password@localhost:5432/topupkilat

# Redis (for caching & queues)
REDIS_URL=redis://localhost:6379

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@topupkilat.com

# Storage (for future uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=topupkilat-assets

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Error Tracking
SENTRY_DSN=https://example@sentry.io/xxxxx
