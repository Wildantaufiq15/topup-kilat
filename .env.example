# =====================================================
# Topup Kilat - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# =====================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Topup Kilat
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase (Backend Database & Auth)
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Digiflazz API (Game Topup Supplier)
# Production credentials - Get from: https://member.digiflazz.com/buyer-area/connection/api
# IMPORTANT: Enable Production Mode di dashboard Digiflazz sebelum pakai production key!
DIGIFLAZZ_API_URL=https://api.digiflazz.com/v1
DIGIFLAZZ_PROXY_URL=https://api.topupkilat.store
DIGIFLAZZ_USERNAME=kemikegwdEJo
DIGIFLAZZ_API_KEY=your_production_api_key_here

# Sakurupiah Payment Gateway
# Production credentials - Get from: https://sakurupiah.id/dashboard
SAKURUPIAH_API_ID=your_api_id_here
SAKURUPIAH_API_KEY=your_api_key_here
SAKURUPIAH_API_URL=https://sakurupiah.id/api
SAKURUPIAH_CALLBACK_URL=https://your-domain.com/api/callback/sakurupiah

# Supabase Service Role Key (Server-side only!)
# IMPORTANT: Never expose this key to the frontend!
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Fonnte WhatsApp API (for order notifications)
# Get from: https://fonnte.com/
FONNTE_API_KEY=your_fonnte_api_key_here

# Admin WhatsApp number for notifications (format: 08xxxxxxxxx or +62xxxxxxxxx)
ADMIN_WHATSAPP_NUMBER=08xxxxxxxxx
