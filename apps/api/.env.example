# ============================================
# TOPUP KILAT - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ============================================
# DATABASE (PostgreSQL - Neon/Supabase/Railway)
# ============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@ep-xxx-123456.us-east-2.aws.neon.tech/topupkilat?sslmode=require"

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ============================================
# APPLICATION
# ============================================
PORT=4000
NODE_ENV=production

# Frontend URL (for CORS) - UPDATE THIS TO YOUR VERCEL URL
FRONTEND_URL="https://your-app.vercel.app"

# ============================================
# SAKURUPIAH PAYMENT GATEWAY
# ============================================
# Get these from your Sakurupiah dashboard after verification
SAKURUPIAH_API_URL="https://api.sakurupiah.com"
SAKURUPIAH_MERCHANT_ID="your-merchant-id"
SAKURUPIAH_API_KEY="your-api-key"
SAKURUPIAH_WEBHOOK_SECRET="your-webhook-secret"

# ============================================
# DIGIFLAZZ SUPPLIER API
# ============================================
# Get these from your Digiflazz dashboard after verification
DIGIFLAZZ_API_URL="https://api.digiflazz.com"
DIGIFLAZZ_USERNAME="your-digiflazz-username"
DIGIFLAZZ_API_KEY="your-digiflazz-api-key"

# ============================================
# OTHER SUPPLIERS (Optional)
# ============================================
SUPPLIER_API_URL="https://api.supplier-example.com"
SUPPLIER_API_KEY="your-supplier-api-key"
SUPPLIER_WEBHOOK_SECRET="your-supplier-webhook-secret"
