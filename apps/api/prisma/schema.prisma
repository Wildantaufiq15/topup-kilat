// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String?  @unique
  name         String?
  password     String
  avatar       String?
  role         UserRole @default(USER)
  memberTier   MemberTier @default(BRONZE)
  pointsBalance Int     @default(0)
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  orders        Order[]
  wishlists     Wishlist[]
  pointsLedger  PointsLedger[]
  notifications Notification[]
  refreshTokens RefreshToken[]

  @@index([email])
  @@index([phone])
}

enum UserRole {
  USER
  CS
  FINANCE
  ADMIN
  SUPER_ADMIN
}

enum MemberTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ============================================
// GAMES & PRODUCTS
// ============================================

model Game {
  id              String      @id @default(uuid())
  name            String
  slug            String      @unique
  category        GameCategory
  logo            String
  banner          String?
  description     String?
  requiresServerId Boolean   @default(false)
  isActive        Boolean     @default(true)
  featured        Boolean     @default(false)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  products  GameProduct[]
  orders    Order[]
  wishlists Wishlist[]

  @@index([slug])
  @@index([category])
  @@index([isActive])
}

enum GameCategory {
  MOBILE
  PC
  CONSOLE
  VOUCHER
}

model GameProduct {
  id                   String      @id @default(uuid())
  gameId               String
  label                String
  description          String?
  image                String?
  price                Decimal     @db.Decimal(12, 2)
  originalPrice        Decimal?    @db.Decimal(12, 2)
  discount             Int?        // percentage
  stock                ProductStock @default(AVAILABLE)
  supplierCode         String
  isActive             Boolean     @default(true)
  sortOrder            Int         @default(0)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  // Relations
  game     Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([gameId])
  @@index([isActive])
}

enum ProductStock {
  AVAILABLE
  LIMITED
  EMPTY
}

// ============================================
// VOUCHERS & PROMOS
// ============================================

model Voucher {
  id            String         @id @default(uuid())
  code          String         @unique
  name          String
  description   String?
  discountType  DiscountType
  discountValue Decimal        @db.Decimal(12, 2)
  minTransaction Decimal       @db.Decimal(12, 2) @default(0)
  maxDiscount    Decimal?      @db.Decimal(12, 2)
  quota         Int
  usedQuota     Int            @default(0)
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  orders Order[]

  @@index([code])
  @@index([isActive])
  @@index([startDate, endDate])
}

enum DiscountType {
  PERCENTAGE
  FIXED
  CASHBACK
}

model Promo {
  id        String     @id @default(uuid())
  title     String
  description String?
  image     String
  link      String?
  position   PromoPosition @default(BANNER)
  startDate DateTime
  endDate   DateTime
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([isActive])
  @@index([position])
}

enum PromoPosition {
  BANNER
  POPUP
  BADGE
}

// ============================================
// ORDERS & PAYMENTS
// ============================================

model Order {
  id           String       @id @default(uuid())
  invoiceNo    String       @unique
  userId       String?
  gameId       String
  productId    String
  userGameId   String       // User's game ID
  serverId     String?
  nickname     String?      // Validated nickname from supplier
  voucherId    String?
  voucherCode  String?      // Store code for history
  subtotal     Decimal      @db.Decimal(12, 2)
  discount     Decimal      @default(0) @db.Decimal(12, 2)
  total        Decimal      @db.Decimal(12, 2)
  status       OrderStatus  @default(PENDING_PAYMENT)
  failureReason String?
  idempotencyKey String?    @unique
  retryCount   Int          @default(0)
  paidAt       DateTime?
  completedAt  DateTime?
  expiredAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  user          User?        @relation(fields: [userId], references: [id])
  game          Game         @relation(fields: [gameId], references: [id])
  product       GameProduct  @relation(fields: [productId], references: [id])
  voucher       Voucher?     @relation(fields: [voucherId], references: [id])
  payment       Payment?
  supplierLogs  SupplierRequest[]

  @@index([invoiceNo])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([idempotencyKey])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SUCCESS
  FAILED
  EXPIRED
  REFUNDED
  CANCELLED
}

model Payment {
  id           String        @id @default(uuid())
  orderId      String        @unique
  method       PaymentMethod
  amount       Decimal       @db.Decimal(12, 2)
  status       PaymentStatus @default(PENDING)
  providerRef  String?       // Reference from payment gateway
  paymentUrl   String?       // For redirect/qr code
  qrCode       String?       // Base64 QR code image
  vaNumber     String?       // Virtual account number
  instructions String?       // Payment instructions
  paidAt       DateTime?
  expiredAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  webhookLogs  PaymentWebhookLog[]

  @@index([providerRef])
  @@index([status])
}

enum PaymentMethod {
  QRIS
  GOPAY
  OVO
  DANA
  SHOPEEPAY
  BCA_VA
  BNI_VA
  MANDIRI_VA
  BRI_VA
  PERMATA_VA
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

model PaymentWebhookLog {
  id        String   @id @default(uuid())
  paymentId String
  payload   Json     // Raw webhook payload
  signature  String?  // HMAC signature for verification
  isValid   Boolean  @default(true)
  processedAt DateTime?
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model SupplierRequest {
  id              String         @id @default(uuid())
  orderId        String
  requestPayload Json
  responsePayload Json?
  status         SupplierStatus @default(PENDING)
  retryCount     Int            @default(0)
  errorMessage   String?
  processedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

enum SupplierStatus {
  PENDING
  SUCCESS
  FAILED
}

// ============================================
// USER FEATURES
// ============================================

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
}

model PointsLedger {
  id        String       @id @default(uuid())
  userId    String
  amount    Int          // Positive for earn, negative for redeem
  type      PointsType
  description String?
  orderId   String?      // Related order if applicable
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum PointsType {
  EARN_PURCHASE
  EARN_PROMO
  REDEEM_VOUCHER
  EXPIRED
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String             @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?             // Additional data (orderId, etc.)
  isRead    Boolean           @default(false)
  readAt    DateTime?
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  ORDER_CREATED
  ORDER_PAID
  ORDER_PROCESSING
  ORDER_SUCCESS
  ORDER_FAILED
  PAYMENT_REMINDER
  PROMO_NEW
  POINTS_EARNED
}

// ============================================
// ADMIN & AUDIT
// ============================================

model AdminActivityLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String   // CREATE, UPDATE, DELETE
  entity    String   // orders, games, vouchers, users, etc.
  entityId  String
  changes   Json?    // Before and after values
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ============================================
// CMS CONTENT
// ============================================

model CmsContent {
  id        String   @id @default(uuid())
  key       String   @unique // e.g., 'faq', 'about', 'terms'
  title     String
  content   String   // Markdown or HTML
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
